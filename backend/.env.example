# ── Five Fingers Backend – Konfiguration ─────────────────────────────
# Diese Datei ist eine VORLAGE. Kopieren nach .env und echte Werte eintragen.
# Die echte .env NIEMALS committen (steht in .gitignore).

# Anthropic API-Key (https://console.anthropic.com/ → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude-Modell (Standard: claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# Port des HTTP-Servers
PORT=8787

# Firmenkontext, der Claude bei jeder Klassifikation mitgegeben wird.
# Damit werden Entwürfe auf Ihr Unternehmen zugeschnitten.
COMPANY_NAME=Muster GmbH
COMPANY_BRANCHE=Handwerk
COMPANY_SIGNATURE=Mit freundlichen Grüßen\nIhr Muster-Team

# ── Optional: Gmail-Anbindung (siehe src/gmail.js) ───────────────────
# OAuth2-Zugangsdaten aus der Google Cloud Console (Desktop-App-Typ).
# Nur nötig, wenn Sie echte Postfächer statt der /classify-API nutzen.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
